und":557739984,"textPrimary":4278523707,"textSecondary":4280042124,"invertedBackground":4279845263,"overlayBackground":3422885691},"darkThemeColorPalette":{"baseBackground":4278258461,"raisedBackground":4278523707,"additiveBackground":725512144,"textPrimary":4292798717,"textSecondary":4288329454,"invertedBackground":4286357220,"overlayBackground":3422885691},"position":"FACTOID_POSITION_LAST","enableColorSampledText":true}}],"channelNavigationEndpoint":{"clickTrackingParams":"CBUQ040EGAYiEwj1taWC3Z-UAxXKitQCHaMXA6_KAQQ_wgH0","commandMetadata":{"webCommandMetadata":{"url":"/@TechWithHasanAbbasi","webPageType":"WEB_PAGE_TYPE_CHANNEL","rootVe":3611,"apiUrl":"/youtubei/v1/browse"}},"browseEndpoint":{"browseId":"UC-O0Tcx5IgWyalqZ-hU114Q","canonicalBaseUrl":"/@TechWithHasanAbbasi"}},"channelThumbnail":{"thumbnails":[{"url":"https://yt3.ggpht.com/I8XMRpLF0EbldpxMvI41Vuf0jK3tfN1pH7otJ03YyU1BrGin-JktuHMgRU4-J5DjVJYgkVeD=s88-c-k-c0x00ffffff-no-rj"}]}}},{"expandableVideoDescriptionBodyRenderer":{"showMoreText":{"accessibility":{"accessibilityData":{"label":"Show more"}},"simpleText":"...more"},"showLessText":{"simpleText":"Show less"},"attributedDescriptionBodyText":{"content":"دوره آموزشی گیت هاب (GitHub) از مقدماتی تا پیشرفته\nجلسه چهارم - نحوه آپلود (push) کردن پروژه پیاده سازی شده در اکانت گیت هاب\n\nتوی جلسه قبل یاد گرفتیم، چطور پروژه موجود توی اکانت گیت هاب خودمون یا یک شخص دیگر رو دانلود (clone) کنیم، روش تغییرات بدیم، بعد تغییرات اعمال شده رو مجددا در صفحه گیت هاب پروژه (repository) اعمال کنیم. اما سوالی که پیش میاد این هست که اگر یک پروژه رو از قبل پیاده سازی کرده باشیم و روی سیستممون باشه چی؟ چطور اون رو توی سایت گیت هاب آپلود (push) کنیم؟\nتوی این جلسه تمامی مراحل لازم برای این کار رو یاد میگیریم:\n۱. چطور کنترل ورژن گیت رو روی پروژه (initialize) اعمال کنیم؟‌\n۲. چطور یک پروژه (repository) جدید توی گیت هاب درست کنیم و چه تنظیماتی در نظر بگیریم؟\n۳. لینک کردن شاخه (branch) گیت سیستممون به شاخه مربوطه توی سایت چطور انجام میشه؟\n۴. و در نهایت این تغییرات رو توی صفحه پروژه آپلود (push) میکنیم.\n \nلینک جلسات قبل:\nدوره آموزشی گیت هاب 1- آشنایی کامل با GitHub و مزایای آن، بررسی دقیق نحوه کنترل ورژن و جستجوی پروژه\n   • ‫دوره آموزشی گیت هاب 1- آشنایی کامل با Git...  \nدوره آموزشی گیت هاب 2- ساخت اکانت GitHub و نصب آن روی سیستم، ساخت پروژه، اتصال و دانلود پروژه\n   • ‫دوره آموزشی گیت هاب 2- ساخت اکانت GitHub ...  \nدوره آموزش گیت هاب 3- پنج دستور اساسی در چرخه کار با فایلها در پروژه های گیت هاب (GitHub)\n   • ‫دوره آموزش گیت هاب 3- پنج دستور اساسی در ...  \n\nپیشنهاد میکنم به لیست ویدیوهای مرتبط با این آموزش هم یه نگاه بندازین چون مطمئنم به دردتون خواهند خورد.\nلطفا از دانلود ویدیوها اجتناب کنین، برای این ویدیوها زحمت زیادی کشیده شده و به همین دلیل تنها راه استفاده رایگان، تماشای آنلاین هست.\n\n\nدوره ها و جلسات مرتبط:\nآموزش صفر تا صد کگل (Kaggle) برای یادگیری ماشین (Machine Learning) و علم داده (Data Science)\n   • ‫آموزش صفر تا صد کگل (Kaggle) برای یادگیری...  \nنقشه راه یادگیری ماشین (machine learning) از مقدماتی تا پیشرفته    • ‏نقشه راه ماشین لرنینگ (machine learning) ...  \n10 حوزه پرکاربرد ماشین لرنینگ    • ‫10 حوزه پرکاربرد یادگیری ماشین (Machine L...  \nدوره کامل یادگیری ماشین از مقدماتی تا پیشرفته    • دوره کامل ماشین لرنینگ از مقدماتی تا پیشرف...  \nدوره کامل یادگیری عمیق (دیپ لرنینگ)  از مقدماتی تا پیشرفته     • دوره کامل دیپ لرنینگ (deep learning) از مق...  \nدوره کامل شبکه های عصبی کانولوشنی (CNN) از مقدماتی تا پیشرفته    • دوره کامل شبکه عصبی کانولوشنی (CNN) از مقد...  \nپروژه کامل دیپ لرنینگ (Deep Learning) روی دیتاست بیماری قلبی با توضیحات کامل تمامی مراحل پیاده سازی    • ‫پروژه کامل دیپ لرنینگ (Deep Learning) روی...  \nپروژه کامل شبکه عصبی کانولوشنی (CNN) با توضیحات کامل تمامی مراحل پیاده سازی و لایه های شبکه    • ‫پروژه کامل شبکه عصبی کانولوشنی (CNN) با ت...  \n3 پروژه کاملا کاربردی و مبتنی بر واقعیت برای تمرین بیشتر یادگیری ماشین    • ‫3 پروژه کاملا کاربردی و مبتنی بر واقعیت ب...  \nدوره کامل پایتون از مقدماتی تا پیشرفته    • ‫دوره کامل آموزش برنامه نویسی به زبان پایت...  \nپنج پروژه با استفاده از پایتون - از سطح مقدماتی تا پیشرفته    • پنج پروژه با استفاده از پایتون - از سطح مق...  \nموازنه بایاس و واریانس یعنی چی؟ (دلیل overfit یا underfit شدن مدلها چیه؟)    • ‫آموزش یادگیری ماشین 16 - موازنه بایاس و و...  \nآشنایی با کتابخانه matplotlib و دستورات مهم آن در 10 دقیقه    • ‫‫کتابخانه های پرکاربرد در پایتون 3 -‫ آشن...  \nآشنایی با کتابخانه Pandas و دستورات مهم آن در 20 دقیقه    • ‫‫کتابخانه های پرکاربرد در پایتون 2 -‫ ‫آش...  \nآشنایی با کتابخانه numpy و دستورات مهم آن در 20 دقیقه    • ‫کتابخانه های پرکاربرد در پایتون 1 -‫ آشنا...  \n.\nممنون میشم اگر ویدیوها آموزنده هست اونها رو لایک کنید،  توی کانالمون سابسکرایب کنید و اونها رو با دیگران هم به اشتراک بذارین.\n.\nلطفا از دانلود ویدیوها اجتناب کنین، برای این ویدیوها زحمت زیادی کشیده شده (من راضی نیستم که اونها رو دانلود کنید) و به همین دلیل تنها راه استفاده رایگان، تماشای آنلاین هست.\nلینک کانال تلگرام https://t.me/techwithhasanabbasi\n\n\nاگر برای ورود به دنیای برنامه نویسی و آموزش آن به صورت خودآموز نیاز به راهنمایی و مشاوره دارید، میتونین از طریق لینک زیر جهت رزرو زمان مناسب اقدام کنید تا با هم در موردش صحبت کنیم و یه شروع قدرتمند داشته باشین.\nhttps://calendly.com/techwithhasanabb...","commandRuns":[{"startIndex":949,"length":52,"onTap":{"innertubeCommand":{"clickTrackingParams":"CBUQ040EGAYiEwj1taWC3Z-UAxXKitQCHaMXA6_KAQQ_wgH0","commandMetadata":{"webCommandMetadata":{"url":"/watch?v=ER2KB-8Up-Y","webPageType":"WEB_PAGE_TYPE_WATCH","rootVe":3832}},"watchEndpoint":{"videoId":"ER2KB-8Up-Y","startTimeSeconds":0,"watchEndpointSupportedOnesieConfig":{"html5PlaybackOnesieConfig":{"commonConfig":{"url":"https://rr4---sn-vgqsrnez.googlevideo.com/initplayback?source=youtube\u0026oeis=1\u0026c=WEB\u0026oad=3200\u0026ovd=3200\u0026oaad=11000\u0026oavd=11000\u0026ocs=700\u0026oewis=1\u0026oputc=1\u0026ofpcc=1\u0026msp=1\u0026odepv=1\u0026id=111d8a07ef14a7e6\u0026ip=64.236.176.233\u0026initcwndbps=7555000\u0026mt=1777900449\u0026oweuc="}}}}}},"onTapOptions":{"accessibilityInfo":{"accessibilityLabel":"YouTube Channel Link: ‫دوره آمو